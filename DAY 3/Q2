#include <stdio.h>

int main()
{
    int start, end, i, j, isPrime;

    printf("Enter starting number: ");
    scanf("%d", &start);

    printf("Enter ending number: ");
    scanf("%d", &end);

    printf("Prime numbers are:\n");

    for (i = start; i <= end; i++)
    {
        if (i < 2)
            continue;

        isPrime = 1;

        for (j = 2; j * j <= i; j++)
        {
            if (i % j == 0)
            {
                isPrime = 0;
                break;
            }
        }

        if (isPrime)
            printf("%d ", i);
    }

    printf("\n");

    return 0;
}