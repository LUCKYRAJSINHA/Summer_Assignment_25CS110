#include <stdio.h>

int main()
{
    int start, end;
    int n, original, temp;
    int digit, digits, sum, power, i;

    printf("Enter starting number: ");
    scanf("%d", &start);

    printf("Enter ending number: ");
    scanf("%d", &end);

    printf("Armstrong Numbers:\n");

    for(n = start; n <= end; n++)
    {
        if(n == 0)
        {
            printf("0 ");
            continue;
        }

        original = n;
        temp = n;
        digits = 0;
        sum = 0;

        while(temp != 0)
        {
            digits++;
            temp /= 10;
        }

        temp = n;

        while(temp != 0)
        {
            digit = temp % 10;
            power = 1;

            for(i = 1; i <= digits; i++)
            {
                power *= digit;
            }

            sum += power;
            temp /= 10;
        }

        if(sum == original)
        {
            printf("%d ", original);
        }
    }

    return 0;
}